<footer class="bg-gray-50 border-t border-gray-100 py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-1">
        <span class="text-xl font-bold tracking-tighter">{{ shop.name | upcase }}</span>
        <p class="mt-4 text-sm text-gray-500 leading-relaxed">
          Crafting premium footwear for the modern professional. Comfort meets style in every step.
        </p>
      </div>
      
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-black mb-4">Shop</h4>
        <ul class="space-y-2">
          <li><a href="/collections/all" class="text-sm text-gray-600 hover:text-black">All Collections</a></li>
          <li><a href="/products" class="text-sm text-gray-600 hover:text-black">New Arrivals</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-black mb-4">Support</h4>
        <ul class="space-y-2">
          <li><a href="/pages/contact" class="text-sm text-gray-600 hover:text-black">Contact Us</a></li>
          <li><a href="/pages/shipping-policy" class="text-sm text-gray-600 hover:text-black">Shipping Policy</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest text-black mb-4">Newsletter</h4>
        <p class="text-sm text-gray-500 mb-4">Stay updated with our latest collections.</p>
        <div class="flex gap-2">
          <input type="email" placeholder="Email address" class="flex-grow bg-white border border-gray-200 px-4 py-2 rounded-lg text-sm focus:outline-none focus:border-black">
          <button class="bg-black text-white px-4 py-2 rounded-lg text-sm font-medium">Join</button>
        </div>
      </div>
    </div>
    
    <div class="mt-12 pt-8 border-t border-gray-100 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-400">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
