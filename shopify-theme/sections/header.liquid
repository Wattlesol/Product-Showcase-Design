{%- liquid
  assign logo_svg = '<svg viewBox="0 0 100 20" class="h-6 w-auto"><text x="0" y="15" font-family="Inter" font-weight="bold" font-size="16" letter-spacing="-1">LUMINA</text></svg>'
-%}

<header class="sticky top-0 z-50 w-full border-b border-gray-100 bg-white/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-8">
      <a href="/" class="flex items-center gap-2">
        <span class="text-xl font-bold tracking-tighter">{{ shop.name | upcase }}</span>
      </a>
      
      <nav class="hidden md:flex items-center gap-6">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}" class="text-sm font-medium text-gray-600 hover:text-black transition-colors">
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>
    </div>

    <div class="flex items-center gap-4">
      <a href="/cart" class="group relative p-2">
        {% render 'icon-cart' %}
        {%- if cart.item_count > 0 -%}
          <span class="absolute -right-1 -top-1 flex h-4 w-4 items-center justify-center rounded-full bg-black text-[10px] font-bold text-white">
            {{ cart.item_count }}
          </span>
        {%- endif -%}
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
