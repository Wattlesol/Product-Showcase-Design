# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://lumina:YOUR_PASSWORD@142.44.136.233:5435/lumina

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3050

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Used to send order confirmation emails
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USER=admin@wattlesol.com
EMAIL_PASS=YOUR_EMAIL_PASSWORD

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Paste the full JSON contents of your Google Service Account key file.
# Alternatively, Base64-encode the JSON and paste that.
# This is used to log new orders to your Google Sheet.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
